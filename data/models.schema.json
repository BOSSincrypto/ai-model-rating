{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Models snapshot",
  "type": "object",
  "required": [
    "snapshot_date",
    "sources",
    "models"
  ],
  "properties": {
    "snapshot_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "models": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/model"
      },
      "minItems": 15
    }
  },
  "$defs": {
    "model": {
      "type": "object",
      "required": [
        "id",
        "name",
        "provider",
        "type",
        "license",
        "context_window",
        "pricing",
        "scores",
        "rank",
        "updated_at",
        "source_note"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "closed",
            "open"
          ]
        },
        "license": {
          "type": "string",
          "minLength": 1
        },
        "context_window": {
          "type": "integer",
          "minimum": 0
        },
        "pricing": {
          "type": "object",
          "required": [
            "input_per_1m",
            "output_per_1m"
          ],
          "additionalProperties": false,
          "properties": {
            "input_per_1m": {
              "type": "number",
              "minimum": 0
            },
            "output_per_1m": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "scores": {
          "type": "object",
          "required": [
            "lmarena_elo",
            "aa_intelligence",
            "ollm_avg",
            "llmstats_composite",
            "benchlm_overall"
          ],
          "additionalProperties": false,
          "properties": {
            "lmarena_elo": {
              "type": ["number", "null"]
            },
            "aa_intelligence": {
              "type": ["number", "null"]
            },
            "ollm_avg": {
              "type": ["number", "null"]
            },
            "llmstats_composite": {
              "type": ["number", "null"]
            },
            "benchlm_overall": {
              "type": ["number", "null"]
            }
          }
        },
        "rank": {
          "type": "integer",
          "minimum": 1
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "source_note": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
